<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>

<VBox stylesheets="@style-javafx.css" xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.coffrefort.client.controllers.MySharesController"
      spacing="25"
      styleClass="root">

    <padding>
        <Insets top="35" right="35" bottom="30" left="35"/>
    </padding>

    <HBox alignment="BOTTOM_LEFT" spacing="20">
        <VBox spacing="8" HBox.hgrow="ALWAYS">
            <Text fill="#2ecc71" styleClass="title-futuristic" text="Mes Partages" />
            <Text fill="#8b949e" style="-fx-font-size: 14px; -fx-font-family: 'Outfit'; " text="Gérez vos accès sécurisés et révoquez les liens actifs." />
        </VBox>
        <Button onAction="#refresh" styleClass="button-secondary" text="🔄 Actualiser" prefHeight="40" prefWidth="120"/>
    </HBox>

    <TableView fx:id="sharesTable"
               VBox.vgrow="ALWAYS"
               prefHeight="450">
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
        <columns>
            <TableColumn fx:id="resourceCol" text="Nom" prefWidth="180"/>
            <TableColumn fx:id="descriptionCol" text="Description" prefWidth="200"/>
            <TableColumn fx:id="labelCol" text="Note Destinataire" prefWidth="200"/>
            <TableColumn fx:id="expiresCol" text="Expiration" prefWidth="160"/>
            <TableColumn fx:id="remainingCol" text="Utilisations" prefWidth="100"/>
            <TableColumn fx:id="statusCol" text="État" prefWidth="90"/>
            <TableColumn fx:id="actionCol" text="Actions" prefWidth="160"/>
        </columns>
    </TableView>

    <HBox alignment="CENTER_RIGHT" spacing="10">
        <Pagination fx:id="pagination" maxPageIndicatorCount="5" styleClass="pagination-futuristic"/>
    </HBox>

</VBox>