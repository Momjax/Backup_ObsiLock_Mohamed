<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<GridPane fx:id="rootPane" hgap="5"
          minHeight="500.0" minWidth="400.0"
          prefHeight="600.0" prefWidth="450.0"
          style="-fx-background-color: #121417;" vgap="20.0"
          stylesheets="@style-javafx.css"
            xmlns="http://javafx.com/javafx/17"
          xmlns:fx="http://javafx.com/fxml/1"
          fx:controller="com.coffrefort.client.controllers.LoginController">

    <padding>
        <Insets left="50.0" right="50.0" top="40.0" bottom="20.0"/>
    </padding>

    <columnConstraints>
        <ColumnConstraints fillWidth="true"
                           halignment="CENTER"
                           hgrow="ALWAYS"
                           minWidth="300.0"
                           prefWidth="400.0" />
    </columnConstraints>

    <children>

        <!-- Logo et Titre de l'application -->
        <VBox alignment="CENTER" spacing="10" GridPane.rowIndex="0">
            <ImageView fitHeight="120.0"
                       fitWidth="120.0"
                       pickOnBounds="true"
                       preserveRatio="true">
                <image>
                    <Image url="@/images/Logo_CryptoVault.png" />
                </image>
            </ImageView>
            <Text fill="#94E01E" strokeType="OUTSIDE"
                  strokeWidth="0.0" text="ObsiLock"
                  textAlignment="CENTER">
                <font>
                    <Font name="System Bold" size="28.0" />
                </font>
            </Text>
        </VBox>

        <!-- Titre de Connexion -->
        <Text fill="#FFFFFF" strokeType="OUTSIDE"
              strokeWidth="0.0" text="Connexion à votre espace sécurisé"
              textAlignment="CENTER" wrappingWidth="250.0"
              GridPane.rowIndex="2">
            <font>
                <Font name="System" size="18.0" />
            </font>
        </Text>

        <!-- Champ email -->
        <TextField fx:id="emailField"
                   prefHeight="45.0"
                   promptText="Email"
                   style="-fx-background-color: #32373d; -fx-text-fill: white; -fx-prompt-text-fill: #9499a1; -fx-background-radius: 8;"
                   GridPane.rowIndex="4">
        </TextField>

        <!-- Champ mot de passe (masqué / visible via StackPane) -->
        <StackPane GridPane.rowIndex="5">
            <!-- Mot de passe masqué -->
            <PasswordField fx:id="passwordField"
                           prefHeight="45.0"
                           promptText="Mot de passe"
                           style="-fx-background-color: #32373d; -fx-text-fill: white; -fx-prompt-text-fill: #9499a1; -fx-background-radius: 8;">
            </PasswordField>

            <!-- Mot de passe en clair -->
            <TextField fx:id="passwordVisibleField"
                       prefHeight="45.0"
                       promptText="Mot de passe"
                       visible="false"
                       managed="false"
                       style="-fx-background-color: #32373d; -fx-text-fill: white; -fx-prompt-text-fill: #9499a1; -fx-background-radius: 8;">
            </TextField>
        </StackPane>

        <!-- CheckBox pour voir le mot de passe-->
        <HBox spacing="10" alignment="CENTER_LEFT" GridPane.rowIndex="6">
            <CheckBox fx:id="loginSelectShowPassword"
                      mnemonicParsing="false"
                      text="Afficher le mot de passe"
                      textFill="#9499a1"
                      onAction="#handleToggleShowPassword"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Hyperlink fx:id="ForgotPasswordLink"
                       text="Mot de passe oublié ?"
                       style="-fx-text-fill: #9499a1; -fx-cursor: hand; -fx-underline: false;" />
        </HBox>

        <!-- Zone messages -->
        <VBox alignment="CENTER" spacing="5" GridPane.rowIndex="7">
            <Label fx:id="errorLabel"
                   style="-fx-text-fill: #ff4757; -fx-font-weight: bold;"
                   textAlignment="CENTER" />
            <Label fx:id="statusLabel"
                   style="-fx-text-fill: #94E01E; -fx-font-weight: bold;"
                   textAlignment="CENTER" />
        </VBox>

        <!-- Bouton connexion -->
        <Button fx:id="connexionButton"
                alignment="CENTER"
                contentDisplay="CENTER"
                defaultButton="true"
                onAction="#handleLogin"
                prefHeight="45.0"
                prefWidth="300.0"
                style="-fx-background-color: #94E01E; -fx-text-fill: #000000; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;"
                text="Se Connecter"
                GridPane.hgrow="ALWAYS"
                GridPane.rowIndex="8"
                GridPane.vgrow="NEVER">
            <font>
                <Font size="16.0" />
            </font>
        </Button>

        <!-- Lien vers Inscription -->
        <HBox alignment="CENTER" spacing="5.0" GridPane.rowIndex="10">
            <children>
                <Text fill="#9499a1" strokeType="OUTSIDE" strokeWidth="0.0" text="Vous n'avez pas de compte ?">
                    <font>
                        <Font size="13.0" />
                    </font>
                </Text>
                <Hyperlink fx:id="registerLink1"
                           onAction="#handleGoToRegister"
                           style="-fx-text-fill: #94E01E; -fx-cursor: hand;"
                           text="Créer un compte">
                    <font>
                        <Font size="13.0" />
                    </font>
                </Hyperlink>
            </children>
        </HBox>

        <!-- Mentions légales en bas -->
        <Hyperlink fx:id="mentionsLegales"
                   style="-fx-text-fill: #9499a1; -fx-cursor: hand;"
                   text="Mentions Légales" 
                   GridPane.rowIndex="11" />

    </children>
    
    <rowConstraints>
        <RowConstraints />
        <RowConstraints />
        <RowConstraints />
        <RowConstraints />
        <RowConstraints />
        <RowConstraints />
        <RowConstraints />
        <RowConstraints />
        <RowConstraints />
        <RowConstraints />
        <RowConstraints />
        <RowConstraints />
    </rowConstraints>
</GridPane>
