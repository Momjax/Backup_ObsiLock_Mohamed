<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox prefHeight="700" 
      prefWidth="900" 
      spacing="25" 
      styleClass="root"
      xmlns="http://javafx.com/javafx/25" 
      xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.coffrefort.client.controllers.QuotaManagementController">

    <padding>
        <Insets bottom="35" left="35" right="35" top="35"/>
    </padding>

    <!-- En-tête -->
    <HBox spacing="15" alignment="CENTER_LEFT">
        <VBox alignment="CENTER" prefWidth="55" prefHeight="55" 
              style="-fx-background-color: rgba(46, 204, 113, 0.1); -fx-background-radius: 14; -fx-border-color: #2ecc71; -fx-border-radius: 14;">
            <Text text="👥" styleClass="main-title-green" style="-fx-font-size: 26px;"/>
        </VBox>
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Text text="Administration des Quotas" styleClass="main-title-green" style="-fx-font-size: 24px;"/>
            <Text text="Gérez les limites de stockage de vos utilisateurs" styleClass="label-dim" style="-fx-font-size: 13px;"/>
        </VBox>
    </HBox>

    <Separator opacity="0.1"/>

    <!-- Barre de recherche premium -->
    <HBox spacing="15" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="Rechercher par email..." HBox.hgrow="ALWAYS" prefHeight="45"/>
        <Button fx:id="searchButton" text="Rechercher" onAction="#handleSearch" styleClass="button-primary" prefHeight="45" prefWidth="120"/>
        <Button fx:id="refreshButton" text="Actualiser" onAction="#handleRefresh" styleClass="button-secondary" prefHeight="45" prefWidth="120"/>
    </HBox>

    <!-- Table Users -->
    <TableView fx:id="usersTable" VBox.vgrow="ALWAYS">
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
        <columns>
            <TableColumn fx:id="idCol" text="ID" prefWidth="60"/>
            <TableColumn fx:id="emailCol" text="Utilisateur" prefWidth="250"/>
            <TableColumn fx:id="quotaUsedCol" text="Espace utilisé" prefWidth="150"/>
            <TableColumn fx:id="quotaMaxCol" text="Quota total" prefWidth="150"/>
            <TableColumn fx:id="percentCol" text="Occupation" prefWidth="100"/>
            <TableColumn fx:id="roleCol" text="Rôle" prefWidth="100"/>
        </columns>
        <placeholder>
            <VBox alignment="CENTER" spacing="15">
                <Text text="Aucun utilisateur trouvé" fill="#8b949e" style="-fx-font-size: 16px;"/>
                <Button text="Recharger la liste" onAction="#handleRefresh" styleClass="button-secondary"/>
            </VBox>
        </placeholder>
    </TableView>

    <!-- Info label premium -->
    <Label fx:id="infoLabel" visible="false" managed="false" 
           style="-fx-background-color: rgba(46, 204, 113, 0.05); -fx-text-fill: #2ecc71; -fx-padding: 12; -fx-background-radius: 8; -fx-border-color: rgba(46, 204, 113, 0.2); -fx-border-radius: 8; -fx-font-size: 13px;"/>

    <Region VBox.vgrow="ALWAYS"/>

    <!-- Boutons actions -->
    <HBox alignment="CENTER_RIGHT" spacing="15">
        <Button fx:id="closeButton" text="Fermer" onAction="#handleClose" styleClass="button-secondary" prefHeight="45" prefWidth="120"/>
        <Button fx:id="modifyQuotaButton" text="Modifier le Quota" onAction="#handleModifyQuota" disable="true" styleClass="button-primary" prefHeight="45" prefWidth="180"/>
    </HBox>

</VBox>