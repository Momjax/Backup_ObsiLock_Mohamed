<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<GridPane fx:id="rootPane" hgap="5"
          minHeight="500.0" minWidth="400.0"
          prefHeight="700.0" prefWidth="450.0"
          vgap="15.0"
          styleClass="main-root"
            xmlns="http://javafx.com/javafx/17"
          xmlns:fx="http://javafx.com/fxml/1"
          fx:controller="com.coffrefort.client.controllers.LoginController">

    <padding>
        <Insets left="30.0" right="30.0" top="30.0" bottom="20.0"/>
    </padding>

    <columnConstraints>
        <ColumnConstraints fillWidth="true"
                           halignment="CENTER"
                           hgrow="ALWAYS"
                           minWidth="300.0"
                           prefWidth="400.0" />
    </columnConstraints>

    <children>

        <!-- HEADER THEME -->
        <HBox alignment="TOP_RIGHT" GridPane.rowIndex="0">
            <ToggleButton fx:id="themeToggleButton" onAction="#handleToggleTheme" styleClass="theme-switch">
                <graphic>
                    <Region styleClass="thumb" />
                </graphic>
                <tooltip><Tooltip text="Changer le thème" /></tooltip>
            </ToggleButton>
        </HBox>

        <!-- Logo et Titre de l'application -->
        <VBox alignment="CENTER" spacing="10" GridPane.rowIndex="1">
            <ImageView fx:id="logoView" fitHeight="120.0"
                       fitWidth="120.0"
                       pickOnBounds="true"
                       preserveRatio="true">
                <image>
                    <Image url="@/images/Logo_CryptoVault_transparent.png" />
                </image>
            </ImageView>
            <Text strokeType="OUTSIDE"
                  strokeWidth="0.0" text="ObsiLock"
                  styleClass="title-futuristic"
                  textAlignment="CENTER">
            </Text>
        </VBox>

        <!-- Titre de Connexion -->
        <Text styleClass="main-title-green" strokeType="OUTSIDE"
              strokeWidth="0.0" text="Connexion à votre espace sécurisé"
              textAlignment="CENTER" wrappingWidth="250.0"
              GridPane.rowIndex="3">
            <font>
                <Font name="System" size="18.0" />
            </font>
        </Text>

        <!-- Champ email -->
        <TextField fx:id="emailField"
                   prefHeight="50.0"
                   promptText="Email"
                   GridPane.rowIndex="5">
        </TextField>

        <!-- Champ mot de passe (masqué / visible via StackPane) -->
        <StackPane GridPane.rowIndex="6">
            <!-- Mot de passe masqué -->
            <PasswordField fx:id="passwordField"
                           prefHeight="50.0"
                           promptText="Mot de passe">
            </PasswordField>

            <!-- Mot de passe en clair -->
            <TextField fx:id="passwordVisibleField"
                       prefHeight="50.0"
                       promptText="Mot de passe"
                       visible="false"
                       managed="false">
            </TextField>
        </StackPane>

        <!-- CheckBox pour voir le mot de passe-->
        <HBox alignment="CENTER_LEFT" spacing="5" GridPane.rowIndex="7">
            <CheckBox fx:id="loginSelectShowPassword"
                      mnemonicParsing="false"
                      onAction="#handleToggleShowPassword"
                      styleClass="label-dim"
                      text="Afficher le mot de passe" />

            <Region HBox.hgrow="ALWAYS" />

            <Hyperlink fx:id="ForgotPasswordLink"
                       styleClass="link-accent"
                       text="Mot de passe oublié ?" />
        </HBox>

        <!-- Zone messages -->
        <VBox alignment="CENTER" spacing="5" GridPane.rowIndex="8">
            <Label fx:id="errorLabel"
                   styleClass="status-error"
                   textAlignment="CENTER" />
            <Label fx:id="statusLabel"
                   styleClass="status-success"
                   textAlignment="CENTER" />
        </VBox>

        <!-- Bouton connexion -->
        <Button fx:id="connexionButton"
                alignment="CENTER"
                contentDisplay="CENTER"
                defaultButton="true"
                onAction="#handleLogin"
                prefHeight="45.0"
                prefWidth="300.0"
                styleClass="button-primary"
                text="Se Connecter"
                GridPane.hgrow="ALWAYS"
                GridPane.rowIndex="9"
                GridPane.vgrow="NEVER"
                GridPane.columnSpan="2">
            <font>
                <Font size="16.0" />
            </font>
        </Button>

        <!-- Lien vers Connexion -->
        <HBox alignment="CENTER" spacing="5.0" GridPane.rowIndex="10" GridPane.columnSpan="2">
            <children>
                <Text styleClass="main-title-green" strokeType="OUTSIDE" strokeWidth="0.0" text="Vous n'avez pas de compte ?">
                    <font>
                        <Font size="13.0" />
                    </font>
                </Text>
                <Hyperlink fx:id="registerLink1"
                           onAction="#handleGoToRegister"
                           styleClass="link-accent"
                           text="Créer un compte">
                    <font>
                        <Font size="13.0" />
                    </font>
                </Hyperlink>
            </children>
        </HBox>

        <!-- Mentions légales en bas -->
        <Hyperlink fx:id="mentionsLegales"
                   styleClass="label-dim"
                   text="Mentions Légales"
                   GridPane.rowIndex="11" />

    </children>
    
    <rowConstraints>
        <RowConstraints />
        <RowConstraints />
        <RowConstraints />
        <RowConstraints />
        <RowConstraints />
        <RowConstraints />
        <RowConstraints />
        <RowConstraints />
        <RowConstraints />
        <RowConstraints />
        <RowConstraints />
        <RowConstraints />
    </rowConstraints>
</GridPane>
