<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<VBox prefHeight="650"
      prefWidth="720"
      spacing="15"
      style="-fx-background-color: #0d1117;"
      stylesheets="@style-javafx.css"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.coffrefort.client.controllers.MentionsLegalesController">

    <padding>
        <Insets bottom="20" left="25" right="25" top="20" />
    </padding>

    <!-- En-tête -->
    <HBox alignment="CENTER_LEFT" spacing="12">
        <!-- Badge icône -->
        <VBox alignment="CENTER"
              prefWidth="48"
              style="-fx-background-color: #27ae60; -fx-background-radius: 8;">
            <padding>
                <Insets bottom="10" left="10" right="10" top="10" />
            </padding>
            <Text fill="white" style="-fx-font-size: 24px;" text="⚖️" />
        </VBox>

        <!-- Titre -->
        <VBox alignment="CENTER_LEFT" spacing="4" HBox.hgrow="ALWAYS">
            <Text styleClass="title-futuristic" style="-fx-font-size: 24px;" text="Mentions légales" />
            <Text styleClass="label-dim" style="-fx-font-size: 13px;" text="Application CryptoVault" />
        </VBox>

        <!-- Logo -->
        <ImageView fx:id="logoView" fitHeight="80.0" fitWidth="120.0" pickOnBounds="true" preserveRatio="true">
            <image>
                <Image url="@/images/Logo_CryptoVault_transparent.png" />
            </image>
        </ImageView>
    </HBox>

    <Separator style="-fx-opacity: 0.2; -fx-background-color: #27ae60;">
        <VBox.margin>
            <Insets bottom="5" top="10" />
        </VBox.margin>
    </Separator>

    <!-- Contenu scrollable -->
    <ScrollPane fitToWidth="true"
                style="-fx-background-color: transparent; -fx-background: #0d1117; -fx-border-color: transparent;"
                VBox.vgrow="ALWAYS">
        <content>
            <VBox spacing="20" style="-fx-background-color: transparent;">
                <padding>
                    <Insets bottom="18" left="10" right="10" top="10" />
                </padding>

                <!-- Intro -->
                <Label wrapText="true" styleClass="label-dim" style="-fx-text-fill: #8b949e;"
                       text="Les présentes mentions légales décrivent les informations relatives à l’éditeur, l’hébergement, la propriété intellectuelle et la protection des données personnelles liées à l’application CryptoVault." />

                <!-- SECTION: INFORMATIONS LÉGALES -->
                <Text fill="#27ae60" style="-fx-font-weight: bold; -fx-font-size: 16px;" text="Informations légales" />

                <!-- Éditeur -->
                <VBox spacing="10" style="-fx-background-color: #1e8449; -fx-background-radius: 10; -fx-padding: 15;">
                    <Text fill="white" style="-fx-font-weight: bold; -fx-font-size: 14px;" text="Éditeur de l’application" />
                    <HBox spacing="8">
                        <Label style="-fx-font-weight: bold; -fx-text-fill: #1f2328;" text="Raison sociale :" />
                        <Label style="-fx-text-fill: white;" text="CryptoVault Inc" />
                    </HBox>
                    <HBox spacing="8">
                        <Label style="-fx-font-weight: bold; -fx-text-fill: #1f2328;" text="Directeur :" />
                        <Label style="-fx-text-fill: white;" text="[M0mjax]" />
                    </HBox>
                </VBox>

                <!-- Siège social -->
                <VBox spacing="10" style="-fx-background-color: #1e8449; -fx-background-radius: 10; -fx-padding: 15;">
                    <Text fill="white" style="-fx-font-weight: bold; -fx-font-size: 14px;" text="Siège social" />
                    <Label wrapText="true" style="-fx-text-fill: white;"
                           text="Société : CryptoVault Inc&#10;Adresse : [Adresse complète]&#10;[Code postal] [Ville]&#10;[Pays]" />
                </VBox>

                <!-- Hébergement -->
                <Text fill="#27ae60" style="-fx-font-weight: bold; -fx-font-size: 16px;" text="Hébergement" />
                <VBox spacing="10" style="-fx-background-color: #1e8449; -fx-background-radius: 10; -fx-padding: 15;">
                    <Label style="-fx-font-weight: bold; -fx-text-fill: #1f2328;" text="Hébergeur : AlwaysData" />
                    <Label wrapText="true" style="-fx-text-fill: white;"
                           text="Adresse : 91, rue du Faubourg-Saint-Honoré, 75008 Paris, France&#10;Site : www.alwaysdata.com" />
                </VBox>

                <!-- Propriété Intellectuelle -->
                <Text fill="#27ae60" style="-fx-font-weight: bold; -fx-font-size: 16px;" text="Propriété intellectuelle" />
                <VBox spacing="10" style="-fx-background-color: #1f2328; -fx-background-radius: 10; -fx-padding: 15; -fx-border-color: #27ae60; -fx-border-radius: 10;">
                    <Text fill="#27ae60" style="-fx-font-weight: bold;" text="⚠ Interdictions strictes" />
                    <Label wrapText="true" style="-fx-text-fill: white; -fx-font-size: 12px;"
                           text="Toute reproduction ou exploitation non autorisée de l’application ou de ses éléments (interfaces, code, logos) est strictement interdite." />
                </VBox>

                <Separator style="-fx-opacity: 0.1;" />
                <Label fx:id="versionLabel" style="-fx-text-fill: #8b949e; -fx-font-size: 11px;"
                       text="Version de l’application : [0.1.0] • Dernière mise à jour : Février 2026" />
            </VBox>
        </content>
    </ScrollPane>

    <!-- Pied de page -->
    <HBox alignment="CENTER_RIGHT" spacing="15">
        <Button fx:id="returnButton" onAction="#handleReturn"
                style="-fx-background-color: transparent; -fx-text-fill: #8b949e; -fx-cursor: hand; -fx-font-weight: bold;"
                text="Retour" />
        <Button fx:id="closeButton" onAction="#handleClose"
                styleClass="button-vibrant"
                style="-fx-background-radius: 8; -fx-padding: 8 20;"
                text="Fermer" />
    </HBox>

</VBox>
