<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<GridPane fx:id="rootPane" hgap="5"
          minHeight="500.0" minWidth="400.0"
          prefHeight="750.0" prefWidth="450.0"
          vgap="15.0"
          styleClass="main-root"
            xmlns="http://javafx.com/javafx/17"
          xmlns:fx="http://javafx.com/fxml/1"
          fx:controller="com.coffrefort.client.controllers.RegisterController">

    <padding>
        <Insets left="30.0" right="30.0" top="30.0" bottom="20.0"/>
    </padding>

    <columnConstraints>
        <ColumnConstraints fillWidth="true"
                           halignment="CENTER"
                           hgrow="ALWAYS"
                           minWidth="300.0"
                           prefWidth="400.0" />
    </columnConstraints>

    <children>

        <!-- HEADER THEME -->
        <HBox alignment="TOP_RIGHT" GridPane.rowIndex="0">
            <Button fx:id="themeToggleButton" onAction="#handleToggleTheme" 
                    text="☾">
                <tooltip><javafx.scene.control.Tooltip text="Changer le thème" /></tooltip>
            </Button>
        </HBox>

        <!-- Logo et Titre de l'application -->
        <VBox alignment="CENTER" spacing="10" GridPane.rowIndex="1">
            <ImageView fx:id="logoView" fitHeight="120.0"
                       fitWidth="120.0"
                       pickOnBounds="true"
                       preserveRatio="true">
                <image>
                    <Image url="@/images/Logo_CryptoVault_transparent.png" />
                </image>
            </ImageView>
            <Text fill="#2ecc71" strokeType="OUTSIDE"
                  strokeWidth="0.0" text="ObsiLock"
                  styleClass="title-futuristic"
                  textAlignment="CENTER" />
        </VBox>

        <!-- Titre d'Inscription -->
        <Text styleClass="main-title" strokeType="OUTSIDE" strokeWidth="0.0"
              text="Création de votre espace sécurisé"
              textAlignment="CENTER"
              wrappingWidth="250.0" GridPane.rowIndex="3">
            <font>
                <Font name="System" size="18.0" />
            </font>
        </Text>

        <!-- Champ email -->
        <TextField fx:id="emailField1"
                   prefHeight="50.0"
                   promptText="Adresse email"
                   GridPane.rowIndex="5">
        </TextField>

        <!-- Champ mot de passe -->
        <StackPane GridPane.rowIndex="6">
            <!-- Mot de passe masqué -->
            <PasswordField fx:id="passwordField1"
                           prefHeight="50.0"
                           promptText="Mot de passe (Min 12 car, 1 maj, 1 spé)">
            </PasswordField>
            <TextField fx:id="passwordVisibleField1"
                       prefHeight="50.0"
                       promptText="Mot de passe (Min 12 car, 1 maj, 1 spé)"
                       visible="false"
                       managed="false">
            </TextField>
        </StackPane>

        <StackPane GridPane.rowIndex="7">
            <PasswordField fx:id="confirmPasswordField1"
                           prefHeight="50.0"
                           promptText="Confirmer le mot de passe">
            </PasswordField>
            <TextField fx:id="confirmPasswordVisibleField1"
                       prefHeight="50.0"
                       promptText="Confirmer le mot de passe"
                       visible="false"
                       managed="false">
            </TextField>
        </StackPane>

        <!-- CheckBox Afficher Mot de passe -->
        <CheckBox fx:id="loginSelectShowPassword"
                  mnemonicParsing="false"
                  onAction="#handleToggleShowPassword"
                  styleClass="label-dim"
                  text="Afficher le mot de passe"
                  GridPane.rowIndex="8" />

        <!-- Zone messages -->
        <VBox alignment="CENTER" spacing="5" GridPane.rowIndex="9">
            <Label fx:id="errorLabel1"
                   styleClass="status-error"
                   textAlignment="CENTER" 
                   wrapText="true"
                   maxWidth="350.0" />
            <Label fx:id="statusLabel1"
                   styleClass="status-success"
                   textAlignment="CENTER" />
        </VBox>

        <!-- Bouton inscription -->
        <Button fx:id="registerButton1"
                alignment="CENTER"
                contentDisplay="CENTER"
                defaultButton="true"
                onAction="#handleRegister"
                prefHeight="45.0"
                prefWidth="300.0"
                styleClass="button-primary"
                text="S'inscrire"
                GridPane.hgrow="ALWAYS"
                GridPane.rowIndex="10"
                GridPane.vgrow="NEVER">
            <font>
                <Font size="16.0" />
            </font>
        </Button>

        <!-- Lien vers la page de Connexion -->
        <HBox alignment="CENTER" spacing="5.0" GridPane.rowIndex="11">
            <children>
                <Text styleClass="label-dim" strokeType="OUTSIDE" strokeWidth="0.0" text="Déjà inscrit ?">
                    <font>
                        <Font size="13.0" />
                    </font>
                </Text>
                <Hyperlink fx:id="loginLink1"
                           onAction="#handleGoToLogin"
                           styleClass="link-accent"
                           text="Se connecter">
                    <font>
                        <Font size="13.0" />
                    </font>
                </Hyperlink>
            </children>
        </HBox>

        <!-- Mentions légales en bas -->
        <Hyperlink fx:id="mentionsLegales"
                   styleClass="label-dim"
                   text="Mentions Légales"
                   GridPane.rowIndex="12" />

    </children>
</GridPane>
