<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<GridPane fx:id="rootPane" hgap="5"
          minHeight="500.0" minWidth="400.0"
          prefHeight="650.0" prefWidth="450.0"
          vgap="15.0"
          stylesheets="@style-javafx.css"
            xmlns="http://javafx.com/javafx/17"
          xmlns:fx="http://javafx.com/fxml/1"
          fx:controller="com.coffrefort.client.controllers.RegisterController">

    <padding>
        <Insets left="30.0" right="30.0" top="30.0" bottom="20.0"/>
    </padding>

    <columnConstraints>
        <ColumnConstraints fillWidth="true"
                           halignment="CENTER"
                           hgrow="ALWAYS"
                           minWidth="300.0"
                           prefWidth="400.0" />
    </columnConstraints>

    <children>

        <!-- Logo et Titre de l'application -->
        <VBox alignment="CENTER" spacing="10" GridPane.rowIndex="0">
            <ImageView fitHeight="120.0"
                       fitWidth="120.0"
                       pickOnBounds="true"
                       preserveRatio="true">
                <image>
                    <Image url="@/images/Logo_CryptoVault.png" />
                </image>
            </ImageView>
            <Text fill="#2ecc71" strokeType="OUTSIDE"
                  strokeWidth="0.0" text="ObsiLock"
                  styleClass="title-futuristic"
                  textAlignment="CENTER" />
        </VBox>

        <!-- Titre -->
        <Text fill="#FFFFFF" strokeType="OUTSIDE"
              strokeWidth="0.0" text="Créer votre compte sécurisé"
              textAlignment="CENTER" wrappingWidth="300.0"
              GridPane.rowIndex="2">
            <font>
                <Font name="System" size="18.0" />
            </font>
        </Text>

        <!-- Champ email -->
        <TextField fx:id="emailField1"
                   prefHeight="50.0"
                   promptText="Adresse Email"
                   GridPane.rowIndex="4">
        </TextField>

        <!-- Champ mot de passe -->
        <StackPane GridPane.rowIndex="5">
            <!-- Mot de passe masqué -->
            <PasswordField fx:id="passwordField1"
                           prefHeight="50.0"
                           promptText="Mot de passe (Min 12 car, 1 maj, 1 spé)">
            </PasswordField>
            <TextField fx:id="passwordVisibleField1"
                       prefHeight="50.0"
                       promptText="Mot de passe (Min 12 car, 1 maj, 1 spé)"
                       visible="false"
                       managed="false">
            </TextField>
        </StackPane>

        <StackPane GridPane.rowIndex="6">
            <PasswordField fx:id="confirmPasswordField1"
                           prefHeight="50.0"
                           promptText="Confirmer le mot de passe">
            </PasswordField>
            <TextField fx:id="confirmPasswordVisibleField1"
                       prefHeight="50.0"
                       promptText="Confirmer le mot de passe"
                       visible="false"
                       managed="false">
            </TextField>
        </StackPane>

        <!-- CheckBox pour voir le mot de passe-->
        <HBox spacing="10" alignment="CENTER_LEFT" GridPane.rowIndex="7">
            <CheckBox fx:id="loginSelectShowPassword"
                      mnemonicParsing="false"
                      text="Afficher les mots de passe"
                      textFill="#9499a1"
                      onAction="#handleToggleShowPassword"/>
        </HBox>

        <!-- Zone messages -->
        <VBox alignment="CENTER" spacing="5" GridPane.rowIndex="8">
            <Label fx:id="errorLabel1"
                   style="-fx-text-fill: #ff4757; -fx-font-weight: bold; -fx-font-size: 13px;"
                   textAlignment="CENTER" 
                   wrapText="true"
                   maxWidth="350.0" />
            <Label fx:id="statusLabel1"
                   style="-fx-text-fill: #2ecc71; -fx-font-weight: bold;"
                   textAlignment="CENTER" />
        </VBox>

        <!-- Bouton inscription -->
        <Button fx:id="registerButton1"
                alignment="CENTER"
                contentDisplay="CENTER"
                defaultButton="true"
                onAction="#handleRegister"
                prefHeight="45.0"
                prefWidth="300.0"
                styleClass="button-primary"
                text="Créer mon compte"
                GridPane.hgrow="ALWAYS"
                GridPane.rowIndex="9"
                GridPane.vgrow="NEVER">
            <font>
                <Font size="16.0" />
            </font>
        </Button>

        <!-- Lien vers Connexion -->
        <HBox alignment="CENTER" spacing="5.0" GridPane.rowIndex="10">
            <children>
                <Text fill="#9499a1" strokeType="OUTSIDE" strokeWidth="0.0" text="Déjà inscrit ?">
                    <font>
                        <Font size="13.0" />
                    </font>
                </Text>
                <Hyperlink fx:id="loginLink1"
                           onAction="#handleGoToLogin"
                           style="-fx-text-fill: #2ecc71; -fx-cursor: hand;"
                           text="Se connecter">
                    <font>
                        <Font size="13.0" />
                    </font>
                </Hyperlink>
            </children>
        </HBox>

        <!-- Mentions légales en bas -->
        <Hyperlink fx:id="mentionsLegales"
                   style="-fx-text-fill: #9499a1; -fx-cursor: hand;"
                   text="Mentions Légales"
                   GridPane.rowIndex="11" />

    </children>
</GridPane>
