<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox prefHeight="650" 
      prefWidth="850" 
      spacing="20" 
      styleClass="root"
      stylesheets="@style-javafx.css" 
      xmlns="http://javafx.com/javafx/25" 
      xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.coffrefort.client.controllers.FileDetailsController">

    <padding>
        <Insets bottom="35" left="35" right="35" top="35"/>
    </padding>

    <!-- En-tête -->
    <HBox spacing="15" alignment="CENTER_LEFT">
        <VBox alignment="CENTER" prefWidth="55" prefHeight="55" 
              style="-fx-background-color: rgba(46, 204, 113, 0.1); -fx-background-radius: 14; -fx-border-color: #2ecc71; -fx-border-radius: 14;">
            <Text text="📄" fill="#2ecc71" style="-fx-font-size: 26px;"/>
        </VBox>
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label fx:id="fileNameLabel" text="Détails du Fichier" styleClass="title-futuristic" style="-fx-font-size: 22px; -fx-text-fill: #2ecc71;"/>
            <Label fx:id="fileMetaLabel" text="0.0 MB • Dernière modification" styleClass="label-dim" style="-fx-font-size: 13px;"/>
        </VBox>
        <Button fx:id="replaceButton" text="Nouvelle Version" onAction="#onReplace" styleClass="button-primary" prefHeight="45" prefWidth="180"/>
    </HBox>

    <Separator opacity="0.1"/>

    <!-- Zone Progression Uplod (Premium) -->
    <VBox fx:id="progressBox" spacing="12" visible="false" managed="false" 
          style="-fx-padding: 15; -fx-background-color: rgba(255,255,255,0.03); -fx-background-radius: 12; -fx-border-color: rgba(46, 204, 113, 0.2); -fx-border-radius: 12;">
        <Label fx:id="uploadStatusLabel" text="Mise à jour en cours..." styleClass="label-dim"/>
        <ProgressBar fx:id="uploadProgressBar" prefWidth="800" prefHeight="12" progress="0.0" />
        <Label fx:id="errorLabel" visible="false" managed="false" style="-fx-text-fill: #ff4757; -fx-font-weight: bold;"/>
    </VBox>

    <!-- Table des versions -->
    <VBox spacing="15" VBox.vgrow="ALWAYS">
        <HBox alignment="CENTER_LEFT">
            <Text text="Historique des Versions" fill="white" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="versionsCountLabel" text="0 version(s)" styleClass="label-dim"/>
        </HBox>

        <TableView fx:id="versionsTable" VBox.vgrow="ALWAYS">
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
            </columnResizePolicy>
            <columns>
                <TableColumn fx:id="versionCol" text="Version" prefWidth="80"/>
                <TableColumn fx:id="sizeCol" text="Taille" prefWidth="120"/>
                <TableColumn fx:id="dateCol" text="Date de création" prefWidth="180"/>
                <TableColumn fx:id="checksumCol" text="Empreinte SHA-256" prefWidth="300"/>
            </columns>
        </TableView>
        
        <HBox alignment="CENTER_RIGHT">
            <Pagination fx:id="pagination" maxPageIndicatorCount="5" styleClass="pagination-futuristic"/>
        </HBox>
    </VBox>

    <Region VBox.vgrow="ALWAYS"/>

    <!-- footer actions -->
    <HBox alignment="CENTER" spacing="15">
        <Button fx:id="copyChecksumButton" text="Copier Checksum" onAction="#onCopyChecksum" disable="true" styleClass="button-secondary" prefHeight="45" prefWidth="180"/>
        <Button fx:id="openLocalFolderButton" text="Ouvrir dans l'explorateur" onAction="#onOpenLocalFolder" disable="true" styleClass="button-secondary" prefHeight="45" prefWidth="250"/>
        <Button fx:id="downloadVersionButton" text="Télécharger cette Version" onAction="#onDownloadVersion" disable="true" styleClass="button-secondary" prefHeight="45" prefWidth="250"/>
    </HBox>

</VBox>