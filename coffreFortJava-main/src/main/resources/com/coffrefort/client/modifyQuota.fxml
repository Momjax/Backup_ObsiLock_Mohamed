<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox prefHeight="450" 
      prefWidth="550" 
      spacing="20" 
      styleClass="root"
      stylesheets="@style-javafx.css" 
      xmlns="http://javafx.com/javafx/25" 
      xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.coffrefort.client.controllers.ModifyQuotaController">

    <padding>
        <Insets bottom="35" left="35" right="35" top="35"/>
    </padding>

    <!-- En-tête -->
    <HBox spacing="15" alignment="CENTER_LEFT">
        <VBox alignment="CENTER" prefWidth="55" prefHeight="55" 
              style="-fx-background-color: rgba(46, 204, 113, 0.1); -fx-background-radius: 14; -fx-border-color: #2ecc71; -fx-border-radius: 14;">
            <Text text="💾" fill="#2ecc71" style="-fx-font-size: 26px;"/>
        </VBox>
        <VBox spacing="4">
            <Text text="Limites de Stockage" fill="#2ecc71" styleClass="title-futuristic" style="-fx-font-size: 24px;"/>
            <Text text="Ajustez le quota de l'utilisateur" fill="#8b949e" style="-fx-font-size: 13px;"/>
        </VBox>
    </HBox>

    <Separator opacity="0.1"/>

    <!-- Infos Utilisateur (Premium Card) -->
    <VBox spacing="10" style="-fx-background-color: rgba(255,255,255,0.03); -fx-background-radius: 12; -fx-padding: 20; -fx-border-color: rgba(46, 204, 113, 0.1); -fx-border-radius: 12;">
        <HBox spacing="10">
            <Label text="Utilisateur :" styleClass="label-dim" prefWidth="120"/>
            <Label fx:id="usernameLabel" text="user@example.com" style="-fx-text-fill: white; -fx-font-weight: bold;"/>
        </HBox>
        <HBox spacing="10">
            <Label text="Quota actuel :" styleClass="label-dim" prefWidth="120"/>
            <Label fx:id="currentQuotaLabel" text="5.0 GB" style="-fx-text-fill: white;"/>
        </HBox>
        <HBox spacing="10">
            <Label text="Espace utilisé :" styleClass="label-dim" prefWidth="120"/>
            <Label fx:id="usedSpaceLabel" text="2.5 GB" style="-fx-text-fill: #2ecc71; -fx-font-weight: bold;"/>
        </HBox>
    </VBox>

    <!-- Saisie -->
    <VBox spacing="12">
        <Label text="Nouveau quota (en Go)" styleClass="label-dim" style="-fx-font-size: 12px;"/>
        <HBox spacing="15" alignment="CENTER_LEFT">
            <TextField fx:id="quotaField" promptText="Ex: 10" prefHeight="45" prefWidth="150"/>
            <Label text="Go" style="-fx-text-fill: #2ecc71; -fx-font-weight: bold; -fx-font-size: 16px;"/>
        </HBox>

        <!-- Presets -->
        <HBox spacing="8">
            <Button text="1 Go" onAction="#setQuota1GB" styleClass="button-secondary" style="-fx-font-size: 11px; -fx-padding: 6 12;"/>
            <Button text="5 Go" onAction="#setQuota5GB" styleClass="button-secondary" style="-fx-font-size: 11px; -fx-padding: 6 12;"/>
            <Button text="10 Go" onAction="#setQuota10GB" styleClass="button-secondary" style="-fx-font-size: 11px; -fx-padding: 6 12;"/>
            <Button text="50 Go" onAction="#setQuota50GB" styleClass="button-secondary" style="-fx-font-size: 11px; -fx-padding: 6 12;"/>
            <Button text="100 Go" onAction="#setQuota100GB" styleClass="button-secondary" style="-fx-font-size: 11px; -fx-padding: 6 12;"/>
        </HBox>
    </VBox>

    <Label fx:id="errorLabel" visible="false" managed="false" style="-fx-text-fill: #ff4757; -fx-font-weight: bold;"/>

    <Region VBox.vgrow="ALWAYS"/>

    <!-- footer -->
    <HBox alignment="CENTER_RIGHT" spacing="15">
        <Button fx:id="cancelButton" text="Annuler" onAction="#handleCancel" styleClass="button-secondary" prefHeight="45" prefWidth="120"/>
        <Button fx:id="confirmButton" text="Mettre à jour" onAction="#handleConfirm" styleClass="button-primary" prefHeight="45" prefWidth="160"/>
    </HBox>

</VBox>